# -----------------------------------------------------------------------------
# Kopiér til `.env` og udfyld rigtige værdier. Commit ALDRIG `.env` —
# filen er gitignored.
# -----------------------------------------------------------------------------

# Azure AD-autentifikation til audio_streamer-klienten.
# I `dev`-miljø bruges DefaultAzureCredential i stedet, og disse kan
# forblive tomme.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Adgangskode som audio_streamer bruger til at kalde Leverance-backenden.
LEVERANCE_PASSWORD=

# Miljøvælger: `dev` eller `prod`
ENV=dev

# -----------------------------------------------------------------------------
# Azure OpenAI (bruges af aiservice og leverance)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_TRANSCRIBE_DEPLOYMENT=gpt-4o-mini-transcribe
AZURE_OPENAI_API_VERSION=2024-06-01

# -----------------------------------------------------------------------------
# Azure Storage (blob + queue)
# -----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_BLOB_CONTAINER=transcriptions
